{
  "name": "@meetcat/i18n",
  "version": "0.0.6",
  "description": "Internationalization for MeetCat",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "i18next": "^24.2.2",
    "react-i18next": "^15.4.1"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
