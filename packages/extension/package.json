{
  "name": "@meetcat/extension",
  "version": "0.1.0",
  "private": true,
  "description": "MeetCat Chrome Extension",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:content && vite build --watch",
    "build": "rm -rf dist && pnpm build:content && pnpm build:popup && pnpm build:rename",
    "build:rename": "cd dist && mv content-homepage.global.js content-homepage.js && mv content-meeting.global.js content-meeting.js && mv service-worker.global.js service-worker.js",
    "build:content": "tsup",
    "build:popup": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@meetcat/core": "workspace:*",
    "@meetcat/i18n": "workspace:*",
    "@meetcat/settings": "workspace:*",
    "@meetcat/settings-ui": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.301",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
